rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "mail.nasiya@gmail.com";
    }

    function isClient() {
      return isSignedIn() && hasUserDoc() && me().role == "client";
    }

    function isAgent() {
      return isSignedIn() && hasUserDoc() && me().role == "agent";
    }

    function myClientId() { return me().clientId; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == userId || isSuperAdmin() ||
        (isClient() && request.resource.data.clientId == myClientId() &&
         request.resource.data.role == "agent")
      );
      allow update: if isSignedIn() && (
        request.auth.uid == userId || isSuperAdmin() ||
        (isClient() && resource.data.clientId == myClientId())
      );
      allow delete: if isSuperAdmin() ||
        (isClient() && resource.data.clientId == myClientId());
    }

    match /leads/{leadId} {
      // Public form — no login needed
      allow create: if
        (request.resource.data.createdBy == "public") ||
        isSuperAdmin() ||
        (isSignedIn() && isClient() && request.resource.data.clientId == myClientId()) ||
        (isSignedIn() && isAgent() && request.resource.data.clientId == myClientId());

      // Agent sees leads assigned to their UID OR their email (legacy)
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        (isClient() && resource.data.clientId == myClientId()) ||
        (isAgent() && resource.data.clientId == myClientId() && (
          resource.data.assignedTo == request.auth.uid ||
          resource.data.assignedTo == request.auth.token.email ||
          resource.data.assignedTo == request.auth.token.email.lower()
        ))
      );

      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (isClient() && resource.data.clientId == myClientId()) ||
        (isAgent() && resource.data.clientId == myClientId() && (
          resource.data.assignedTo == request.auth.uid ||
          resource.data.assignedTo == request.auth.token.email
        ))
      );

      allow delete: if isSuperAdmin() ||
        (isSignedIn() && isClient() && resource.data.clientId == myClientId());
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() || (
        isSignedIn() && isClient() &&
        request.resource.data.clientId == myClientId() &&
        request.resource.data.role == "agent"
      );
      allow update: if isSuperAdmin() ||
        (isSignedIn() && isClient() && clientId == myClientId());
      allow delete: if isSuperAdmin();
    }

    match /activities/{id} {
      allow read, create, update: if isSignedIn();
      allow delete: if isSuperAdmin() || (isSignedIn() && isClient());
    }
  }
}
